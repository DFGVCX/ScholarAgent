SCHOLAR_ENV=production
SCHOLAR_CORS_ALLOW_ORIGINS=https://scholar.example.com
SCHOLAR_API_KEYS=replace-with-random-key:tenant_id:user_id

SCHOLAR_MYSQL_URL=mysql://scholar:replace-password@db:3306/scholar_agent?charset=utf8mb4
SCHOLAR_REDIS_URL=redis://redis:6379/0
MYSQL_ROOT_PASSWORD=replace-root-password
MYSQL_DATABASE=scholar_agent
MYSQL_USER=scholar
MYSQL_PASSWORD=replace-password

SCHOLAR_ALLOW_MOCK_DATA=false
SCHOLAR_EXTERNAL_SOURCE_PROVIDER=real
SCHOLAR_RAG_EMBEDDING_PROVIDER=lexical
SCHOLAR_RAG_BM25_K1=1.5
SCHOLAR_RAG_BM25_B=0.75
SCHOLAR_RAG_RECENCY_HALF_LIFE_DAYS=365
SCHOLAR_RAG_VECTOR_WEIGHT=0.35
SCHOLAR_RAG_BM25_WEIGHT=0.40
SCHOLAR_RAG_RECENCY_WEIGHT=0.10
SCHOLAR_RAG_PREFERENCE_WEIGHT=0.15

SCHOLAR_LANGFUSE_ENABLED=false
SCHOLAR_LANGFUSE_PUBLIC_KEY=
SCHOLAR_LANGFUSE_SECRET_KEY=
SCHOLAR_LANGFUSE_BASE_URL=https://cloud.langfuse.com
SCHOLAR_LANGFUSE_ENVIRONMENT=production

SCHOLAR_PRIMARY_MODEL_PROVIDER=openai-compatible
SCHOLAR_SECONDARY_MODEL_PROVIDER=none
SCHOLAR_LLM_BASE_URL=https://api.example.com
SCHOLAR_LLM_API_KEY=replace-model-key
SCHOLAR_LLM_MODEL=replace-model-name
SCHOLAR_ANTHROPIC_BASE_URL=https://api.anthropic.com
SCHOLAR_ANTHROPIC_API_KEY=
SCHOLAR_ANTHROPIC_MODEL=

SCHOLAR_MCP_TOKEN=replace-mcp-token
SCHOLAR_BROWSER_WORKER_TOKEN=replace-browser-worker-token
SCHOLAR_BROWSER_HEADLESS=true
