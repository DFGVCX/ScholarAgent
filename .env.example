SCHOLAR_ENV=development
SCHOLAR_CORS_ALLOW_ORIGINS=*
SCHOLAR_API_KEYS=demo-key:tenant_demo:user_demo,acme-key:tenant_acme:user_acme

# MySQL bootstrap uses the admin URL once to create the database and app user.
SCHOLAR_MYSQL_ADMIN_URL=mysql://root:root@localhost:3306/mysql?charset=utf8mb4
SCHOLAR_MYSQL_URL=mysql://scholar:scholar@127.0.0.1:3306/scholar_agent?charset=utf8mb4
SCHOLAR_STORAGE_BACKEND=auto

# Redis is used for rate limiting and task event streams when a real Redis server is available.
SCHOLAR_REDIS_URL=redis://127.0.0.1:6379/0

# Mock is opt-in only. Keep false for product verification.
SCHOLAR_ALLOW_MOCK_DATA=false
SCHOLAR_EXTERNAL_SOURCE_PROVIDER=real
SCHOLAR_RAG_EMBEDDING_PROVIDER=lexical
SCHOLAR_RAG_BM25_K1=1.5
SCHOLAR_RAG_BM25_B=0.75
SCHOLAR_RAG_RECENCY_HALF_LIFE_DAYS=365
SCHOLAR_RAG_VECTOR_WEIGHT=0.35
SCHOLAR_RAG_BM25_WEIGHT=0.40
SCHOLAR_RAG_RECENCY_WEIGHT=0.10
SCHOLAR_RAG_PREFERENCE_WEIGHT=0.15

# Optional distributed tracing. Disabled until real credentials are provided.
SCHOLAR_LANGFUSE_ENABLED=false
SCHOLAR_LANGFUSE_PUBLIC_KEY=
SCHOLAR_LANGFUSE_SECRET_KEY=
SCHOLAR_LANGFUSE_BASE_URL=https://cloud.langfuse.com
SCHOLAR_LANGFUSE_ENVIRONMENT=development
SCHOLAR_MODEL_CACHE_ENABLED=true
SCHOLAR_MODEL_CACHE_MAX_ENTRIES=256

# LLM provider options: openai-compatible, openai, anthropic, claude, deterministic(test only), none.
SCHOLAR_PRIMARY_MODEL_PROVIDER=none
SCHOLAR_SECONDARY_MODEL_PROVIDER=none
SCHOLAR_LLM_BASE_URL=https://api.openai.com
SCHOLAR_LLM_API_KEY=
SCHOLAR_LLM_MODEL=
SCHOLAR_ANTHROPIC_BASE_URL=https://api.anthropic.com
SCHOLAR_ANTHROPIC_API_KEY=
SCHOLAR_ANTHROPIC_MODEL=

SCHOLAR_STORAGE_DIR=storage/runtime
SCHOLAR_UPLOAD_DIR=storage/uploads
SCHOLAR_RUNTIME_CONFIG_PATH=storage/runtime/runtime_config.json

# Standard MCP Streamable HTTP endpoint. Keep the token outside Git.
SCHOLAR_MCP_URL=http://127.0.0.1:8001/mcp/
SCHOLAR_MCP_TOKEN=
SCHOLAR_MCP_HOST=127.0.0.1
SCHOLAR_MCP_PORT=8001
SCHOLAR_BROWSER_WORKER_URL=http://127.0.0.1:8002
SCHOLAR_BROWSER_WORKER_TOKEN=
SCHOLAR_BROWSER_HEADLESS=false
